{
  "name": "voice-ime-rust",
  "private": true,
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:desktop": "tauri build",
    "tauri:android:init": "tauri android init",
    "tauri:android:build": "tauri android build --apk",
    "tauri:ios:build": "node -e \"console.error('iOS/IPA build requires macOS, Xcode and a Tauri CLI that exposes the ios command. Use packaging/Build-CrossPlatform.ps1 -Platform ios on that host.'); process.exit(1)\"",
    "ui:smoke": "node scripts/ui-smoke.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "lucide": "^0.511.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.2",
    "playwright": "^1.60.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
